#!/bin/sh
{{ $manifest := dig "packages" "manifestPath" "" . -}}
{{ if eq $manifest "" }}
# No packages.manifestPath configured; skipping package installation.
exit 0
{{ end }}
MANIFEST={{ $manifest | quote }}

if [ ! -f "$MANIFEST" ]; then
    echo "packages.manifestPath '$MANIFEST' not found; skipping package installation."
    exit 0
fi

GENERATOR="$(chezmoi source-path)/.pkgmgmt/generate_packages.py"
if [ ! -f "$GENERATOR" ]; then
    echo "Package generator not found at $GENERATOR; skipping."
    exit 0
fi

internet_available() {
    if command -v curl >/dev/null 2>&1; then
        curl -fsSLI --connect-timeout 2 --max-time 5 https://github.com >/dev/null 2>&1
        return $?
    fi
    if command -v wget >/dev/null 2>&1; then
        wget -q --spider --timeout=5 https://github.com >/dev/null 2>&1
        return $?
    fi
    return 1
}

if ! internet_available; then
    echo "No internet connection detected; skipping package installation."
    exit 0
fi

TMPDIR_PKG=$(mktemp -d)
trap 'rm -rf "$TMPDIR_PKG"' EXIT

echo "Generating package lists from $MANIFEST..."
python3 "$GENERATOR" --manifest "$MANIFEST" --output-dir "$TMPDIR_PKG"

install_brew() {
    command -v brew >/dev/null 2>&1 && return 0
    echo "Installing Homebrew..."
    /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
}

{{ if eq .chezmoi.os "darwin" -}}
echo "macOS detected - installing via Homebrew"
xcode-select --install 2>/dev/null || true
install_brew
if [ -f /opt/homebrew/bin/brew ]; then
    eval "$(/opt/homebrew/bin/brew shellenv)"
elif [ -f /usr/local/bin/brew ]; then
    eval "$(/usr/local/bin/brew shellenv)"
fi
if [ -f "$TMPDIR_PKG/Brewfile" ]; then
    brew bundle --no-upgrade --file="$TMPDIR_PKG/Brewfile"
fi
{{ else if eq .chezmoi.os "linux" -}}
echo "Linux detected - installing via native package manager"
if command -v apt-get >/dev/null 2>&1; then
    if [ -f "$TMPDIR_PKG/packages-apt.txt" ]; then
        packages=$(grep -v '^#' "$TMPDIR_PKG/packages-apt.txt" | grep -v '^$' | tr '\n' ' ')
        sudo apt-get update -qq
        # shellcheck disable=SC2086
        sudo apt-get install --no-upgrade -y $packages
    fi
elif command -v pacman >/dev/null 2>&1; then
    if [ -f "$TMPDIR_PKG/packages-pacman.txt" ]; then
        packages=$(grep -v '^#' "$TMPDIR_PKG/packages-pacman.txt" | grep -v '^$' | tr '\n' ' ')
        # shellcheck disable=SC2086
        sudo pacman -S --needed --noconfirm $packages
    fi
elif command -v dnf >/dev/null 2>&1; then
    if [ -f "$TMPDIR_PKG/packages-dnf.txt" ]; then
        packages=$(grep -v '^#' "$TMPDIR_PKG/packages-dnf.txt" | grep -v '^$' | tr '\n' ' ')
        # shellcheck disable=SC2086
        sudo dnf install -y $packages
    fi
elif [ -f /mingw64/bin/pacman ]; then
    if [ -f "$TMPDIR_PKG/packages-msys2.txt" ]; then
        packages=$(grep -v '^#' "$TMPDIR_PKG/packages-msys2.txt" | grep -v '^$' | tr '\n' ' ')
        # shellcheck disable=SC2086
        pacman -S --needed --noconfirm $packages
    fi
fi
{{ end -}}
echo "Package installation complete."
